# ============================================
# SEEK THE THRILL — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Site
SITE_URL=https://seekthethrill.in

# Admin
ADMIN_EMAIL=zahra@seekthethrill.in
ADMIN_PASSWORD=changeme

# Email — Option 1: Gmail SMTP (use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Email — Option 2: Resend (comment out Gmail above)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Database (only if using Turso — otherwise SQLite local is auto-configured)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

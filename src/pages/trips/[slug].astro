---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import ItineraryAccordion from '../../components/ItineraryAccordion';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import { formatCurrency, formatDateRange } from '../../lib/utils';

export const prerender = false;

const { slug } = Astro.params;

const reader = createReader(process.cwd(), keystaticConfig);
const trip = await reader.collections.trips.read(slug!);

if (!trip) return Astro.redirect('/trips/');

// Load site settings for fallback payment info
let settings: any = {};
try {
  settings = await reader.singletons.siteSettings.read() ?? {};
} catch (e) {}

const name = (trip.name as string) || slug;
const dateRange = formatDateRange(trip.startDate, trip.endDate);
const price = trip.pricePerPerson;
const formattedPrice = price ? formatCurrency(price) : 'TBD';
const seatsLeft = trip.maxGroupSize && trip.currentBookings != null ? trip.maxGroupSize - trip.currentBookings : null;
const qrCode = trip.paymentQrCode ?? settings.defaultQrCode;
const paymentInstructions = trip.paymentInstructions ?? settings.defaultPaymentInstructions;
const paymentAmount = trip.paymentAmount ?? price;
const fullPaymentAmount = (trip as any).fullPaymentAmount ?? price;

const today = new Date().toISOString().split('T')[0];
// Registration form is ONLY shown when admin has explicitly set the trip to "booking-open".
const regOpen = trip.status === 'booking-open';

const heroImg = trip.featuredImage ?? 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1920&auto=format&fit=crop&q=80';

const itineraryData = (trip.itinerary ?? []).map((day: any) => ({
  dayNumber: day.dayNumber ?? 1,
  dayTitle: day.dayTitle ?? '',
  activities: day.activities ?? '',
  accommodation: day.accommodation ?? '',
  breakfast: day.breakfast ?? false,
  lunch: day.lunch ?? false,
  dinner: day.dinner ?? false,
  mealsNotes: day.mealsNotes ?? '',
  transport: day.transport ?? '',
  specialNotes: day.specialNotes ?? '',
}));
---

<BaseLayout
  title={`${name} — Seek the Thrill`}
  description={trip.shortDescription ?? `Join us for ${name} — an adventure with Seek the Thrill.`}
  image={trip.featuredImage ?? undefined}
>

  <!-- HERO -->
  <section
    class="relative overflow-hidden pt-16"
    style={`height: clamp(280px, 50vh, 65vh); background-image: url('${heroImg}'); background-size: cover; background-position: center;`}
  >
    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 60%, rgba(0,0,0,0.15) 100%);"></div>

    <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-10">
      <div class="container-app">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mb-4 leading-tight" style="font-family: var(--font-display);">
          {name}
        </h1>
        <!-- Quick info pills -->
        <div class="flex flex-wrap gap-2">
          {dateRange && (
            <span class="flex items-center gap-1.5 text-sm text-white bg-white/20 backdrop-blur px-3 py-1.5 rounded-full">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {dateRange}
            </span>
          )}
          {trip.duration && (
            <span class="flex items-center gap-1.5 text-sm text-white bg-white/20 backdrop-blur px-3 py-1.5 rounded-full">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {trip.duration}
            </span>
          )}
          {price && (
            <span class="flex items-center gap-1.5 text-sm text-white font-bold bg-accent/80 backdrop-blur px-3 py-1.5 rounded-full" style="background-color: rgba(232,117,42,0.85);">
              {formattedPrice} / person
            </span>
          )}
          {trip.difficulty && <Badge variant="difficulty" value={trip.difficulty} />}
          {trip.status && <Badge variant="status" value={trip.status} />}
        </div>
      </div>
    </div>
  </section>

  <!-- STICKY CTA BAR (desktop) -->
  <div
    id="sticky-cta"
    class="hidden lg:flex sticky top-16 lg:top-20 z-30 bg-white border-b shadow-sm items-center justify-between px-6 py-3"
    style="border-color: var(--color-border);"
  >
    <div class="container-app flex items-center justify-between w-full">
      <div>
        <span class="font-bold text-lg" style="font-family: var(--font-display);">{name}</span>
        {price && <span class="ml-3 font-extrabold text-xl" style="color: var(--color-primary);">{formattedPrice}</span>}
      </div>
      {regOpen ? (
        <a href="#register" class="font-bold text-white px-6 py-2.5 rounded-xl transition-all hover:opacity-90" style="background-color: var(--color-accent);">
          Register Now →
        </a>
      ) : (
        <span class="text-sm px-4 py-2 rounded-xl" style="background-color: #f3f4f6; color: var(--color-text-secondary);">
          Registration Closed
        </span>
      )}
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="container-app py-10">
    <div class="lg:grid lg:grid-cols-[1fr_380px] gap-10 items-start">

      <!-- LEFT COLUMN -->
      <div class="space-y-12">

        <!-- About this trip -->
        <section>
          <h2 class="text-2xl font-extrabold mb-4" style="font-family: var(--font-display);">About This Trip</h2>
          {trip.shortDescription && (
            <p class="text-base leading-relaxed mb-4" style="color: var(--color-text-secondary);">{trip.shortDescription}</p>
          )}

          {(trip.highlights ?? []).length > 0 && (
            <div class="mt-6">
              <h3 class="text-lg font-bold mb-3" style="font-family: var(--font-display);">Trip Highlights</h3>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {(trip.highlights as string[]).map((h) => (
                  <li class="flex items-start gap-2.5 text-sm">
                    <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: var(--color-success);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    {h}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </section>

        <!-- Itinerary -->
        {itineraryData.length > 0 && (
          <section>
            <h2 class="text-2xl font-extrabold mb-6" style="font-family: var(--font-display);">
              Your Day-by-Day Itinerary
            </h2>
            <ItineraryAccordion itinerary={itineraryData} client:visible />
          </section>
        )}

        <!-- Inclusions / Exclusions -->
        {((trip.included ?? []).length > 0 || (trip.notIncluded ?? []).length > 0) && (
          <section>
            <h2 class="text-2xl font-extrabold mb-6" style="font-family: var(--font-display);">
              What's Included
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {(trip.included ?? []).length > 0 && (
                <div>
                  <h3 class="font-bold text-base mb-3 flex items-center gap-2" style="color: var(--color-success);">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Included
                  </h3>
                  <ul class="space-y-2">
                    {(trip.included as string[]).map((item) => (
                      <li class="flex items-start gap-2 text-sm">
                        <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: var(--color-success);" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {(trip.notIncluded ?? []).length > 0 && (
                <div>
                  <h3 class="font-bold text-base mb-3 flex items-center gap-2" style="color: var(--color-danger);">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    Not Included
                  </h3>
                  <ul class="space-y-2">
                    {(trip.notIncluded as string[]).map((item) => (
                      <li class="flex items-start gap-2 text-sm">
                        <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style="color: var(--color-danger);" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </section>
        )}

        <!-- Important Info -->
        <section>
          <h2 class="text-2xl font-extrabold mb-4" style="font-family: var(--font-display);">Important Information</h2>
          <div class="space-y-4">

            {trip.meetingPoint && (
              <details class="border rounded-xl overflow-hidden" style="border-color: var(--color-border);">
                <summary class="px-5 py-4 font-bold cursor-pointer flex items-center gap-2 select-none" style="font-family: var(--font-display);">
                  <svg class="w-5 h-5" style="color: var(--color-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  Meeting Point
                </summary>
                <div class="px-5 pb-4 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                  {trip.meetingPoint}
                  {trip.meetingTime && <div class="mt-2 font-medium">Meeting Time: <strong>{trip.meetingTime}</strong></div>}
                </div>
              </details>
            )}

            {(trip.packingList ?? []).length > 0 && (
              <details class="border rounded-xl overflow-hidden" style="border-color: var(--color-border);">
                <summary class="px-5 py-4 font-bold cursor-pointer flex items-center gap-2 select-none" style="font-family: var(--font-display);">
                  <svg class="w-5 h-5" style="color: var(--color-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                  </svg>
                  Packing List
                </summary>
                <div class="px-5 pb-4">
                  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
                    {(trip.packingList as string[]).map((item) => (
                      <li class="flex items-center gap-2 text-sm">
                        <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </details>
            )}

            {trip.importantNotes && (
              <details class="border rounded-xl overflow-hidden" style="border-color: var(--color-border);">
                <summary class="px-5 py-4 font-bold cursor-pointer flex items-center gap-2 select-none" style="font-family: var(--font-display);">
                  <svg class="w-5 h-5" style="color: var(--color-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Important Notes
                </summary>
                <div class="px-5 pb-4 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
                  {trip.importantNotes}
                </div>
              </details>
            )}

            {(trip.cancellationPolicy ?? settings.cancellationPolicy) && (
              <details class="border rounded-xl overflow-hidden" style="border-color: var(--color-border);">
                <summary class="px-5 py-4 font-bold cursor-pointer flex items-center gap-2 select-none" style="font-family: var(--font-display);">
                  <svg class="w-5 h-5" style="color: var(--color-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Cancellation Policy
                </summary>
                <div class="px-5 pb-4 text-sm leading-relaxed whitespace-pre-line" style="color: var(--color-text-secondary);">
                  {trip.cancellationPolicy ?? settings.cancellationPolicy}
                </div>
              </details>
            )}
          </div>
        </section>

        <!-- Gallery -->
        {(trip.gallery ?? []).length > 0 && (
          <section>
            <h2 class="text-2xl font-extrabold mb-6" style="font-family: var(--font-display);">Trip Gallery</h2>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-3">
              {(trip.gallery as any[]).map((item, i) => (
                <a
                  href={item.image}
                  data-gallery="trip"
                  data-title={item.caption ?? `Photo ${i + 1}`}
                  class="block relative overflow-hidden rounded-xl aspect-square group"
                >
                  <img
                    src={item.image}
                    alt={item.caption ?? `Gallery photo ${i + 1}`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" style="background: rgba(0,0,0,0.4);">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      <!-- RIGHT SIDEBAR -->
      <div class="lg:sticky lg:top-36 space-y-6 mt-8 lg:mt-0">

        <!-- Booking card -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border-t-4" style="border-color: var(--color-primary);">
          <div class="p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                {price ? (
                  <div>
                    <span class="text-3xl font-extrabold" style="font-family: var(--font-display); color: var(--color-primary);">{formattedPrice}</span>
                    <span class="text-sm ml-1" style="color: var(--color-text-secondary);">/ person</span>
                  </div>
                ) : (
                  <span class="text-xl font-bold" style="color: var(--color-primary);">Price TBD</span>
                )}
              </div>
              <Badge variant="status" value={trip.status ?? 'upcoming'} />
            </div>

            <!-- Key details -->
            <ul class="space-y-3 mb-6">
              {dateRange && (
                <li class="flex items-center gap-3 text-sm">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span><strong>Dates:</strong> {dateRange}</span>
                </li>
              )}
              {trip.duration && (
                <li class="flex items-center gap-3 text-sm">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span><strong>Duration:</strong> {trip.duration}</span>
                </li>
              )}
              {trip.maxGroupSize && (
                <li class="flex items-center gap-3 text-sm">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span><strong>Group Size:</strong> {trip.minGroupSize ?? '?'}–{trip.maxGroupSize}</span>
                </li>
              )}
              {trip.difficulty && (
                <li class="flex items-center gap-3 text-sm">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  <span><strong>Difficulty:</strong> <Badge variant="difficulty" value={trip.difficulty} /></span>
                </li>
              )}
              {seatsLeft !== null && (
                <li class="flex items-center gap-3 text-sm">
                  <svg class="w-4 h-4 flex-shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                  </svg>
                  <span><strong>Seats Left:</strong> <span style={seatsLeft <= 3 ? 'color: var(--color-danger); font-weight: bold;' : ''}>{seatsLeft}</span></span>
                </li>
              )}
            </ul>

            {seatsLeft !== null && seatsLeft <= 5 && seatsLeft > 0 && (
              <div class="mb-4 p-3 rounded-lg text-sm font-medium text-center" style="background-color: #fee2e2; color: #991b1b;">
                🔥 Only {seatsLeft} spot{seatsLeft !== 1 ? 's' : ''} left! Book now.
              </div>
            )}

            {regOpen ? (
              <a
                href="#register"
                class="w-full font-bold text-white py-3.5 rounded-xl transition-all hover:opacity-90 text-center block text-base"
                style="background-color: var(--color-accent);"
              >
                Register Now ↓
              </a>
            ) : (
              <div class="w-full py-3.5 rounded-xl text-center text-sm font-medium" style="background-color: #f3f4f6; color: var(--color-text-secondary);">
                Registration {trip.status === 'completed' ? 'Completed' : 'Closed'}
              </div>
            )}

            <!-- Share -->
            <div class="flex items-center justify-center gap-4 mt-4 pt-4 border-t" style="border-color: var(--color-border);">
              <span class="text-xs" style="color: var(--color-text-secondary);">Share:</span>
              <button
                id="share-wa"
                class="text-xs flex items-center gap-1 font-medium px-3 py-1.5 rounded-lg transition-colors"
                style="background-color: #dcfce7; color: #166534;"
              >
                WhatsApp
              </button>
              <button
                id="copy-link"
                class="text-xs flex items-center gap-1 font-medium px-3 py-1.5 rounded-lg transition-colors"
                style="background-color: var(--color-primary-light); color: var(--color-primary);"
              >
                Copy Link
              </button>
            </div>
          </div>
        </div>

        <!-- Payment section -->
        {paymentInstructions && (
          <div class="bg-white rounded-2xl shadow-md p-6">
            <h3 class="text-lg font-bold mb-4" style="font-family: var(--font-display);">How to Pay</h3>
            {qrCode && (
              <div class="text-center mb-4">
                <img src={qrCode} alt="Payment QR Code" class="w-40 h-40 object-contain mx-auto rounded-xl border" style="border-color: var(--color-border);" />
              </div>
            )}
            {paymentAmount && (
              <div class="text-center mb-4">
                <span class="text-2xl font-extrabold" style="color: var(--color-primary); font-family: var(--font-display);">
                  {formatCurrency(paymentAmount)}
                </span>
                <span class="text-sm ml-1" style="color: var(--color-text-secondary);">to pay</span>
              </div>
            )}
            <div class="text-sm leading-relaxed whitespace-pre-line" style="color: var(--color-text-secondary);">
              {paymentInstructions}
            </div>
          </div>
        )}

      </div>
    </div>

    <!-- REGISTRATION FORM -->
    <div id="register" class="mt-16 scroll-mt-24">
      {regOpen ? (
        <div>
          <div class="text-center mb-10">
            <h2 class="text-2xl lg:text-3xl font-extrabold" style="font-family: var(--font-display);">
              Secure Your Spot on {name}
            </h2>
            <p class="mt-2" style="color: var(--color-text-secondary);">
              Fill in your details below to register. Spots are limited!
            </p>
          </div>

          <!-- Inline registration form (simplified direct form, not multi-step for brevity here — link to separate page) -->
          <div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-xl p-8">
            <div id="reg-form-container">
              <form id="reg-form" class="space-y-6">
                <!-- Hidden fields -->
                <input type="hidden" name="tripName" value={name} />
                <input type="hidden" name="tripDate" value={dateRange} />
                <input type="hidden" name="tripDuration" value={trip.duration ?? ''} />
                <!-- Honeypot -->
                <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

                <!-- Personal Info Section -->
                <div>
                  <h3 class="font-bold text-lg mb-4" style="font-family: var(--font-display);">Personal Information</h3>
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="sm:col-span-2">
                      <label class="block text-sm font-medium mb-1">Full Name <span style="color: var(--color-accent);">*</span></label>
                      <input type="text" name="fullName" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1">Email Address <span style="color: var(--color-accent);">*</span></label>
                      <input type="email" name="email" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1">Phone Number <span style="color: var(--color-accent);">*</span></label>
                      <input type="tel" name="phone" placeholder="+91 XXXXX XXXXX" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1">Gender <span style="color: var(--color-accent);">*</span></label>
                      <select name="gender" required class="w-full px-4 py-3 border rounded-xl text-sm bg-white" style="border-color: var(--color-border);">
                        <option value="">Select gender</option>
                        <option value="male">Male</option>
                        <option value="female">Female</option>
                        <option value="non-binary">Non-binary</option>
                        <option value="prefer-not-to-say">Prefer not to say</option>
                      </select>
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1">City <span style="color: var(--color-accent);">*</span></label>
                      <input type="text" name="city" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1">Emergency Contact Name <span style="color: var(--color-accent);">*</span></label>
                      <input type="text" name="emergencyName" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                    </div>
                    <div>
                      <label class="block text-sm font-medium mb-1">Emergency Contact Phone <span style="color: var(--color-accent);">*</span></label>
                      <input type="tel" name="emergencyPhone" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                    </div>
                  </div>
                </div>

                <hr style="border-color: var(--color-border);" />

                <!-- Why Join Section -->
                <div>
                  <label class="block text-sm font-medium mb-1">Why do you want to join this trip? <span style="color: var(--color-accent);">*</span></label>
                  <textarea name="whyJoin" required rows="4" placeholder="Tell us a little about yourself and why this trip excites you..." class="w-full px-4 py-3 border rounded-xl outline-none text-sm resize-none" style="border-color: var(--color-border);"></textarea>
                </div>

                <hr style="border-color: var(--color-border);" />

                <!-- Payment Section -->
                <div>
                  <h3 class="font-bold text-lg mb-4" style="font-family: var(--font-display);">Payment Details</h3>

                  <!-- Advance + Full payment info box -->
                  <div class="rounded-xl mb-5 overflow-hidden border" style="border-color: var(--color-border);">
                    <div class="flex items-center justify-between flex-wrap gap-x-2 gap-y-1 px-3 sm:px-5 py-4 border-b" style="border-color: var(--color-border); background-color: var(--color-primary-light);">
                      <span class="text-sm font-medium">Advance / Booking Amount <span class="text-xs font-normal">(pay now to confirm spot)</span></span>
                      <strong class="text-lg" style="color: var(--color-primary); font-family: var(--font-display);">
                        {paymentAmount ? `₹${paymentAmount.toLocaleString('en-IN')}` : 'TBD'}
                      </strong>
                    </div>
                    <div class="flex items-center justify-between flex-wrap gap-x-2 gap-y-1 px-3 sm:px-5 py-4">
                      <span class="text-sm font-medium">Full Trip Amount <span class="text-xs font-normal">(due 15 days before trip)</span></span>
                      <strong class="text-lg" style="color: var(--color-primary); font-family: var(--font-display);">
                        {fullPaymentAmount ? `₹${fullPaymentAmount.toLocaleString('en-IN')}` : (price ? `₹${price.toLocaleString('en-IN')}` : 'TBD')}
                      </strong>
                    </div>
                  </div>

                  {qrCode && (
                    <div class="text-center mb-6">
                      <img src={qrCode} alt="Payment QR Code" class="w-40 h-40 md:w-48 md:h-48 object-contain mx-auto rounded-xl border" style="border-color: var(--color-border);" />
                      <p class="text-xs mt-2" style="color: var(--color-text-secondary);">Scan to pay via UPI</p>
                    </div>
                  )}

                  {paymentInstructions && (
                    <div class="text-sm leading-relaxed whitespace-pre-line mb-5 p-4 rounded-xl" style="background-color: var(--color-primary-light); color: var(--color-text-secondary);">
                      {paymentInstructions}
                    </div>
                  )}

                  <div>
                    <label class="block text-sm font-medium mb-1">
                      Payment Screenshot
                      <span class="text-xs font-normal ml-1" style="color: var(--color-text-secondary);">(optional)</span>
                    </label>
                    <div id="upload-zone" class="border-2 border-dashed rounded-xl p-6 text-center cursor-pointer transition-colors" style="border-color: var(--color-border);">
                      <svg class="w-8 h-8 mx-auto mb-2" style="color: var(--color-text-secondary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                      </svg>
                      <p class="text-sm" style="color: var(--color-text-secondary);">Click to upload or drag & drop</p>
                      <p class="text-xs mt-1" style="color: var(--color-text-secondary);">JPG, PNG, PDF up to 5MB</p>
                      <input type="file" id="screenshot-file" accept=".jpg,.jpeg,.png,.pdf" class="hidden" />
                    </div>
                    <input type="hidden" name="paymentScreenshotUrl" id="screenshot-url" />
                    <div id="upload-preview" class="hidden mt-2 text-sm" style="color: var(--color-success);"></div>
                  </div>
                </div>

                <hr style="border-color: var(--color-border);" />

                <!-- Agreements -->
                <div class="space-y-3">
                  <label class="flex items-start gap-3 cursor-pointer">
                    <input type="checkbox" name="agreeTerms" required class="mt-1" />
                    <span class="text-sm">I agree to the <a href="/terms/" target="_blank" class="underline" style="color: var(--color-accent);">Terms and Conditions</a> <span style="color: var(--color-accent);">*</span></span>
                  </label>
                  <label class="flex items-start gap-3 cursor-pointer">
                    <input type="checkbox" name="agreeCancel" required class="mt-1" />
                    <span class="text-sm">I have read the Cancellation Policy <span style="color: var(--color-accent);">*</span></span>
                  </label>
                </div>

                <!-- Error message -->
                <div id="form-error" class="hidden p-4 rounded-xl text-sm font-medium" style="background-color: #fee2e2; color: #991b1b;"></div>

                <!-- Submit button -->
                <button
                  type="submit"
                  id="submit-btn"
                  class="w-full font-bold text-white py-3.5 rounded-xl transition-all hover:opacity-90 text-base"
                  style="background-color: var(--color-success);"
                >
                  Submit Registration 🎉
                </button>
              </form>
            </div>
          </div>
        </div>
      ) : (
        <div class="max-w-xl mx-auto text-center py-12 px-6 bg-white rounded-2xl shadow-md">
          <svg class="w-16 h-16 mx-auto mb-4" style="color: var(--color-border);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <h3 class="text-xl font-bold mb-2" style="font-family: var(--font-display);">Registration Closed</h3>
          <p style="color: var(--color-text-secondary);">
            {trip.status === 'completed'
              ? 'This trip has already taken place.'
              : trip.status === 'sold-out'
              ? 'All spots for this trip are filled.'
              : 'Registration for this trip is currently closed.'}
          </p>
          <a href="/trips/" class="inline-block mt-6 font-bold text-white px-6 py-3 rounded-xl" style="background-color: var(--color-accent);">
            Browse Other Trips →
          </a>
        </div>
      )}
    </div>
  </div>

  <!-- Mobile fixed CTA bar -->
  {regOpen && (
    <div class="lg:hidden fixed bottom-0 left-0 right-0 z-40 bg-white border-t shadow-lg px-4 py-3 flex items-center justify-between" style="border-color: var(--color-border);">
      <div>
        {price && <span class="text-xl font-extrabold" style="font-family: var(--font-display); color: var(--color-primary);">{formattedPrice}</span>}
        <span class="text-xs block" style="color: var(--color-text-secondary);">per person</span>
      </div>
      <a href="#register" class="font-bold text-white px-8 py-3 rounded-xl" style="background-color: var(--color-accent);">
        Register Now
      </a>
    </div>
  )}

</BaseLayout>

<style>
  /* Registration form — polished focus states */
  #reg-form input:focus,
  #reg-form select:focus,
  #reg-form textarea:focus {
    border-color: var(--color-primary) !important;
    box-shadow: 0 0 0 3px rgba(45, 95, 62, 0.12);
    outline: none;
  }
  #reg-form select {
    background-color: white;
    cursor: pointer;
  }
  #reg-form label {
    letter-spacing: 0.01em;
  }
</style>

<script>
  const form = document.getElementById('reg-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn');
  const errorDiv = document.getElementById('form-error');

  // File upload
  const uploadZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('screenshot-file') as HTMLInputElement;
  const screenshotUrl = document.getElementById('screenshot-url') as HTMLInputElement;
  const uploadPreview = document.getElementById('upload-preview');

  uploadZone?.addEventListener('click', () => fileInput?.click());
  uploadZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    (uploadZone as HTMLElement).style.borderColor = 'var(--color-accent)';
  });
  uploadZone?.addEventListener('dragleave', () => {
    (uploadZone as HTMLElement).style.borderColor = 'var(--color-border)';
  });
  uploadZone?.addEventListener('drop', (e: DragEvent) => {
    e.preventDefault();
    (uploadZone as HTMLElement).style.borderColor = 'var(--color-border)';
    if (e.dataTransfer?.files[0]) handleFileUpload(e.dataTransfer.files[0]);
  });
  fileInput?.addEventListener('change', () => {
    if (fileInput.files?.[0]) handleFileUpload(fileInput.files[0]);
  });

  async function handleFileUpload(file: File) {
    if (!uploadPreview) return;
    uploadPreview.textContent = 'Uploading...';
    uploadPreview.style.color = 'var(--color-text-secondary)';
    uploadPreview.classList.remove('hidden');

    const fd = new FormData();
    fd.append('file', file);
    try {
      const res = await fetch('/api/upload', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.url) {
        screenshotUrl!.value = data.url;
        uploadPreview.textContent = '✓ ' + file.name + ' uploaded successfully';
        uploadPreview.style.color = 'var(--color-success)';
      } else {
        uploadPreview.textContent = data.error ?? 'Upload failed';
        uploadPreview.style.color = 'var(--color-danger)';
      }
    } catch {
      uploadPreview.textContent = 'Upload failed. Please try again.';
      uploadPreview.style.color = 'var(--color-danger)';
    }
  }

  // Form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errorDiv) errorDiv.classList.add('hidden');

    const fd = new FormData(form);
    const body: Record<string, any> = {};
    fd.forEach((v, k) => { body[k] = v; });

    // Honeypot check (client-side)
    if (body._honey) return;

    try {
      if (submitBtn) {
        (submitBtn as HTMLButtonElement).disabled = true;
        submitBtn.textContent = 'Submitting...';
      }

      const res = await fetch('/api/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();

      if (data.success) {
        const tripName = encodeURIComponent(String(body.tripName ?? ''));
        window.location.href = `/thank-you/?trip=${tripName}`;
      } else {
        if (errorDiv) {
          errorDiv.textContent = data.error ?? 'Registration failed. Please try again.';
          errorDiv.classList.remove('hidden');
        }
        if (submitBtn) {
          (submitBtn as HTMLButtonElement).disabled = false;
          submitBtn.textContent = 'Submit Registration 🎉';
        }
      }
    } catch {
      if (errorDiv) {
        errorDiv.textContent = 'Network error. Please check your connection and try again.';
        errorDiv.classList.remove('hidden');
      }
      if (submitBtn) {
        (submitBtn as HTMLButtonElement).disabled = false;
        submitBtn.textContent = 'Submit Registration 🎉';
      }
    }
  });

  // Share buttons
  document.getElementById('share-wa')?.addEventListener('click', () => {
    window.open(`https://wa.me/?text=${encodeURIComponent(window.location.href)}`, '_blank');
  });
  document.getElementById('copy-link')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    const btn = document.getElementById('copy-link') as HTMLButtonElement;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = 'Copy Link'; }, 2000);
  });
</script>

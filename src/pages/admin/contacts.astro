---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDb } from '../../lib/db';
export const prerender = false;

const contacts = getDb()
  .prepare('SELECT * FROM contact_submissions ORDER BY id DESC')
  .all() as Record<string, any>[];

function fmt(date: string) {
  if (!date) return '—';
  return new Date(date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function statusStyle(status: string) {
  if (status === 'resolved') return 'background:#D1FAE5;color:#065F46;';
  return 'background:#FEF3C7;color:#92400E;';
}
---

<AdminLayout title="Contact Submissions" activeTab="contacts">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
    <div>
      <h1 style="font-family:var(--font-display);font-size:1.5rem;font-weight:800;color:var(--color-primary-dark);margin:0 0 0.25rem;">Contact Submissions</h1>
      <p style="color:var(--color-text-secondary);font-size:0.875rem;margin:0;">{contacts.length} total messages</p>
    </div>
    <a
      href="/api/admin/export?type=contacts"
      style="padding:0.45rem 1rem;background:var(--color-primary);color:white;border-radius:0.5rem;font-size:0.875rem;font-weight:600;text-decoration:none;"
    >
      ↓ Export CSV
    </a>
  </div>

  <!-- Filter bar -->
  <div style="display:flex;gap:0.5rem;margin-bottom:1rem;">
    {['all','new','resolved'].map(s => (
      <button
        class="contact-filter"
        data-filter={s}
        style={`padding:0.35rem 0.9rem;border-radius:9999px;font-size:0.78rem;font-weight:600;cursor:pointer;border:1.5px solid var(--color-border);background:${s==='all'?'var(--color-primary)':'var(--color-surface)'};color:${s==='all'?'white':'var(--color-text-secondary)'};`}
      >
        {s === 'all' ? 'All' : s.charAt(0).toUpperCase() + s.slice(1)}
      </button>
    ))}
  </div>

  <div style="overflow-x:auto; -webkit-overflow-scrolling:touch; border-radius:0.75rem;">
  <div style="background:white;border:1px solid var(--color-border);border-radius:0.75rem;overflow:hidden;min-width:600px;">
    {contacts.length === 0 ? (
      <p style="text-align:center;padding:3rem;color:var(--color-text-secondary);">No contact submissions yet.</p>
    ) : (
      <table style="width:100%;border-collapse:collapse;font-size:0.875rem;">
        <thead>
          <tr style="background:var(--color-surface);border-bottom:2px solid var(--color-border);">
            {['#', 'Name', 'Email', 'Subject', 'Status', 'Date', ''].map(h => (
              <th style="padding:0.65rem 0.875rem;text-align:left;font-size:0.75rem;font-weight:700;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.04em;">{h}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {contacts.map((c, i) => (
            <>
              <tr class="contact-row" data-status={c.status ?? 'new'} style={`border-bottom:1px solid var(--color-border);${i % 2 === 1 ? 'background:#FAFAF7;' : ''}`}>
                <td style="padding:0.65rem 0.875rem;color:var(--color-text-secondary);font-size:0.75rem;">{c.id}</td>
                <td style="padding:0.65rem 0.875rem;font-weight:600;">{c.full_name}</td>
                <td style="padding:0.65rem 0.875rem;">
                  <a href={`mailto:${c.email}`} style="color:var(--color-primary);">{c.email}</a>
                </td>
                <td style="padding:0.65rem 0.875rem;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{c.subject}</td>
                <td style="padding:0.65rem 0.875rem;">
                  <span style={`padding:0.2rem 0.6rem;border-radius:9999px;font-size:0.75rem;font-weight:700;${statusStyle(c.status ?? 'new')}`}>
                    {c.status ?? 'new'}
                  </span>
                </td>
                <td style="padding:0.65rem 0.875rem;white-space:nowrap;color:var(--color-text-secondary);font-size:0.8rem;">{fmt(c.created_at as string)}</td>
                <td style="padding:0.65rem 0.875rem;">
                  <button
                    onclick={`toggleContact(${c.id})`}
                    style="font-size:0.75rem;color:var(--color-primary);background:none;border:1px solid var(--color-primary);border-radius:0.35rem;padding:0.2rem 0.6rem;cursor:pointer;"
                  >
                    View
                  </button>
                </td>
              </tr>

              <!-- Detail row -->
              <tr id={`contact-${c.id}`} style="display:none;">
                <td colspan="7" style="padding:1.25rem 1.5rem;background:#F0FDF4;border-bottom:2px solid var(--color-border);">
                  <div style="display:grid;grid-template-columns:1fr auto;gap:1.5rem;align-items:start;">
                    <div>
                      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.4rem 1.5rem;font-size:0.82rem;margin-bottom:1rem;">
                        <div><span style="color:var(--color-text-secondary);font-weight:600;">Name:</span> {c.full_name}</div>
                        <div><span style="color:var(--color-text-secondary);font-weight:600;">Email:</span> {c.email}</div>
                        <div><span style="color:var(--color-text-secondary);font-weight:600;">Phone:</span> {c.phone ?? '—'}</div>
                        <div><span style="color:var(--color-text-secondary);font-weight:600;">Source:</span> {c.source ?? '—'}</div>
                      </div>
                      <p style="font-size:0.82rem;font-weight:600;color:var(--color-text-secondary);margin:0 0 0.4rem;">Message:</p>
                      <div style="background:white;border:1px solid var(--color-border);border-radius:0.5rem;padding:0.875rem;font-size:0.875rem;white-space:pre-wrap;line-height:1.6;">{c.message}</div>
                    </div>
                    <div style="display:flex;flex-direction:column;gap:0.5rem;min-width:140px;">
                      <a
                        href={`mailto:${c.email}?subject=Re: ${encodeURIComponent(c.subject)}`}
                        style="display:block;padding:0.5rem 1.25rem;background:var(--color-accent);color:white;border-radius:0.5rem;font-size:0.82rem;font-weight:700;text-decoration:none;text-align:center;white-space:nowrap;"
                      >
                        Reply via Email
                      </a>
                      <button
                        onclick={`toggleResolved(${c.id}, '${c.status ?? 'new'}')`}
                        id={`resolve-btn-${c.id}`}
                        style={`padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.82rem;font-weight:700;cursor:pointer;border:none;white-space:nowrap;${(c.status ?? 'new') === 'resolved' ? 'background:#F3F4F6;color:#6B7280;' : 'background:#D1FAE5;color:#065F46;'}`}
                      >
                        {(c.status ?? 'new') === 'resolved' ? '↩ Reopen' : '✓ Mark Resolved'}
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
            </>
          ))}
        </tbody>
      </table>
    )}
  </div>
  </div>
</AdminLayout>

<script>
  function toggleContact(id: number) {
    const row = document.getElementById('contact-' + id);
    if (!row) return;
    row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
  }

  async function toggleResolved(id: number, currentStatus: string) {
    const newStatus = currentStatus === 'resolved' ? 'new' : 'resolved';
    try {
      const res = await fetch('/api/admin/mark-contact-resolved', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, status: newStatus }),
      });
      if (!res.ok) throw new Error('Failed');
      // Update badge in the main row
      const rows = document.querySelectorAll<HTMLTableRowElement>('.contact-row');
      rows.forEach(row => {
        const btn = row.querySelector(`button[onclick*="toggleContact(${id})"]`);
        if (btn) {
          row.dataset.status = newStatus;
          const badge = row.querySelector('span[style*="border-radius:9999px"]') as HTMLElement | null;
          if (badge) {
            badge.textContent = newStatus;
            badge.style.cssText = `padding:0.2rem 0.6rem;border-radius:9999px;font-size:0.75rem;font-weight:700;${newStatus === 'resolved' ? 'background:#D1FAE5;color:#065F46;' : 'background:#FEF3C7;color:#92400E;'}`;
          }
        }
      });
      // Update the resolve button
      const resolveBtn = document.getElementById('resolve-btn-' + id) as HTMLButtonElement | null;
      if (resolveBtn) {
        resolveBtn.textContent = newStatus === 'resolved' ? '↩ Reopen' : '✓ Mark Resolved';
        resolveBtn.style.cssText = `padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.82rem;font-weight:700;cursor:pointer;border:none;white-space:nowrap;${newStatus === 'resolved' ? 'background:#F3F4F6;color:#6B7280;' : 'background:#D1FAE5;color:#065F46;'}`;
        resolveBtn.setAttribute('onclick', `toggleResolved(${id}, '${newStatus}')`);
      }
      // Apply active filter
      applyContactFilter();
    } catch {
      alert('Failed to update status.');
    }
  }

  // Filter buttons
  let activeFilter = 'all';
  function applyContactFilter() {
    const rows = document.querySelectorAll<HTMLTableRowElement>('.contact-row');
    rows.forEach(row => {
      const status = row.dataset.status ?? 'new';
      const show = activeFilter === 'all' || status === activeFilter;
      row.style.display = show ? '' : 'none';
      // Hide open detail row too
      const viewBtn = row.querySelector('button[onclick*="toggleContact"]');
      const id = viewBtn?.getAttribute('onclick')?.match(/\d+/)?.[0];
      if (!show && id) {
        const detail = document.getElementById('contact-' + id);
        if (detail) detail.style.display = 'none';
      }
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.contact-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      activeFilter = btn.dataset.filter ?? 'all';
      // Update button styles
      document.querySelectorAll<HTMLButtonElement>('.contact-filter').forEach(b => {
        const active = b.dataset.filter === activeFilter;
        b.style.background = active ? 'var(--color-primary)' : 'var(--color-surface)';
        b.style.color = active ? 'white' : 'var(--color-text-secondary)';
        b.style.borderColor = active ? 'var(--color-primary)' : 'var(--color-border)';
      });
      applyContactFilter();
    });
  });

  (window as any).toggleContact = toggleContact;
  (window as any).toggleResolved = toggleResolved;
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

let settings: any = {};
try {
  const reader = createReader(process.cwd(), keystaticConfig);
  settings = await reader.singletons.siteSettings.read() ?? {};
} catch (e) {}

const email = settings.email ?? 'zahra@seekthethrill.in';
const phone = settings.phone ?? '+91-7975027491';
const whatsapp = settings.whatsappLink ?? `https://wa.me/917975027491`;
const instagram = settings.instagram ?? 'https://instagram.com/seekthethrill';

const faqs = [
  {
    q: 'How do I book a trip?',
    a: 'Browse our upcoming trips and click "Book Now" on any trip page. Fill in the registration form with your personal and payment details, upload your payment screenshot, and submit. Our team will confirm your booking within 24 hours.',
  },
  {
    q: 'What is your cancellation policy?',
    a: 'Cancellations made 30+ days before the trip receive a full refund (minus a ₹500 processing fee). 15-29 days: 50% refund. 7-14 days: 25% refund. Less than 7 days: no refund. All cancellations must be in writing.',
  },
  {
    q: 'Are trips suitable for solo travelers?',
    a: 'Absolutely! Most of our travelers are solo adventurers who join as individuals. Our group trips are the perfect way to meet new people and make friends. You\'ll never feel alone on a Seek the Thrill trip!',
  },
  {
    q: "What's included in the price?",
    a: 'Each trip has its own inclusions listed on the trip page. Generally, we include transportation, accommodation, meals as mentioned, a trip leader, entry fees for activities, and basic first aid support.',
  },
  {
    q: 'Do you offer group discounts?',
    a: 'Yes! If you bring 5+ friends on the same trip, contact us for a group discount. Reach out via WhatsApp or email to discuss pricing.',
  },
  {
    q: 'What should I bring on a trip?',
    a: 'Each trip page has a detailed packing list. Generally: comfortable trekking/casual clothes, sturdy footwear, sunscreen, water bottle, personal medications, and a camera. Specific gear requirements are listed per trip.',
  },
];
---

<BaseLayout
  title="Contact Us — Seek the Thrill"
  description="Get in touch with Seek the Thrill. Questions about trips, bookings, or just want to chat about adventure? We'd love to hear from you!"
>
  <!-- Hero -->
  <section
    class="relative flex items-center justify-center overflow-hidden pt-20"
    style="height: 35vh; background-image: url('https://images.unsplash.com/photo-1517649763962-0c623066013b?w=1920&auto=format&fit=crop&q=80'); background-size: cover; background-position: center;"
  >
    <div class="absolute inset-0" style="background: rgba(0,0,0,0.55);"></div>
    <div class="relative z-10 text-center px-4">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-3" style="font-family: var(--font-display);">Get in Touch</h1>
      <p class="text-base md:text-lg text-white/80">Have questions? We'd love to hear from you!</p>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-16 lg:py-20" style="background-color: var(--color-surface);">
    <div class="container-app">
      <div class="grid grid-cols-1 lg:grid-cols-[2fr_3fr] gap-12">

        <!-- Contact info -->
        <div class="space-y-4 reveal">
          <h2 class="text-2xl font-extrabold mb-6" style="font-family: var(--font-display);">Contact Information</h2>

          <a href={`mailto:${email}`} class="flex items-start gap-4 p-5 bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow group">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: var(--color-primary-light);">
              <svg class="w-6 h-6" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-sm mb-0.5" style="font-family: var(--font-display);">Email Us</div>
              <div class="text-sm group-hover:underline" style="color: var(--color-accent);">{email}</div>
              <div class="text-xs mt-1" style="color: var(--color-text-secondary);">We reply within 24-48 hours</div>
            </div>
          </a>

          <a href={`tel:${phone}`} class="flex items-start gap-4 p-5 bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow group">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: var(--color-primary-light);">
              <svg class="w-6 h-6" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-sm mb-0.5" style="font-family: var(--font-display);">Call / WhatsApp</div>
              <div class="text-sm group-hover:underline" style="color: var(--color-accent);">{phone}</div>
              <div class="text-xs mt-1" style="color: var(--color-text-secondary);">Mon–Sat, 9 AM – 7 PM IST</div>
            </div>
          </a>

          <a href={whatsapp} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 p-4 rounded-2xl font-bold text-white transition-all hover:opacity-90" style="background-color: #25D366;">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Chat on WhatsApp
          </a>

          <!-- Social -->
          <div class="pt-4">
            <p class="text-sm font-bold mb-3">Follow Us</p>
            <div class="flex gap-4">
              <a href={instagram} target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-xl flex items-center justify-center transition-colors hover:opacity-80 text-white" style="background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);" aria-label="Instagram">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Contact form -->
        <div class="reveal">
          <h2 class="text-2xl font-extrabold mb-6" style="font-family: var(--font-display);">Send Us a Message</h2>
          <div class="bg-white rounded-2xl shadow-md p-6 lg:p-8">
            <form id="contact-form" class="space-y-4">
              <!-- Honeypot -->
              <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium mb-1.5">Full Name <span style="color: var(--color-accent);">*</span></label>
                  <input type="text" name="fullName" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                </div>
                <div>
                  <label class="block text-sm font-medium mb-1.5">Email Address <span style="color: var(--color-accent);">*</span></label>
                  <input type="email" name="email" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium mb-1.5">Phone</label>
                  <input type="tel" name="phone" class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);" />
                </div>
                <div>
                  <label class="block text-sm font-medium mb-1.5">Subject <span style="color: var(--color-accent);">*</span></label>
                  <select name="subject" required class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);">
                    <option value="">Select a topic</option>
                    <option>Trip Inquiry</option>
                    <option>Booking Issue</option>
                    <option>Group Booking</option>
                    <option>Cancellation/Refund</option>
                    <option>General Question</option>
                    <option>Feedback</option>
                    <option>Partnership</option>
                  </select>
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium mb-1.5">Message <span style="color: var(--color-accent);">*</span></label>
                <textarea name="message" required rows="5" class="w-full px-4 py-3 border rounded-xl outline-none text-sm resize-none" style="border-color: var(--color-border);"></textarea>
              </div>

              <div>
                <label class="block text-sm font-medium mb-1.5">How did you hear about us?</label>
                <select name="source" class="w-full px-4 py-3 border rounded-xl outline-none text-sm" style="border-color: var(--color-border);">
                  <option value="">Select...</option>
                  <option>Instagram</option><option>Facebook</option><option>Friend</option><option>Google</option><option>Other</option>
                </select>
              </div>

              <div id="contact-error" class="hidden p-4 rounded-xl text-sm" style="background-color: #fee2e2; color: #991b1b;"></div>
              <div id="contact-success" class="hidden p-4 rounded-xl text-sm font-medium" style="background-color: #dcfce7; color: #166534;"></div>

              <button
                type="submit"
                class="w-full font-bold text-white py-4 rounded-xl transition-all hover:opacity-90 text-base"
                style="background-color: var(--color-accent);"
              >
                Send Message →
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-16 lg:py-20 bg-white scroll-mt-20">
    <div class="container-app">
      <div class="text-center mb-12 reveal">
        <h2 class="text-2xl lg:text-3xl font-extrabold" style="font-family: var(--font-display);">
          Frequently Asked Questions
        </h2>
      </div>

      <div class="max-w-3xl mx-auto space-y-3 reveal">
        {faqs.map((faq, i) => (
          <details class="border rounded-xl overflow-hidden group" style="border-color: var(--color-border);">
            <summary class="px-6 py-4 font-bold cursor-pointer select-none flex items-center justify-between list-none" style="font-family: var(--font-display);">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 flex-shrink-0 transition-transform group-open:rotate-180" style="color: var(--color-accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const errorDiv = document.getElementById('contact-error') as HTMLElement;
  const successDiv = document.getElementById('contact-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    successDiv.classList.add('hidden');

    const fd = new FormData(form);
    const body: Record<string, string> = {};
    fd.forEach((v, k) => { body[k] = v.toString(); });

    if (body._honey) return;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();

      if (data.success) {
        successDiv.textContent = '✓ Message sent! We\'ll get back to you within 24-48 hours.';
        successDiv.classList.remove('hidden');
        form.reset();
      } else {
        errorDiv.textContent = data.error ?? 'Something went wrong. Please try again.';
        errorDiv.classList.remove('hidden');
      }
    } catch {
      errorDiv.textContent = 'Network error. Please try again.';
      errorDiv.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message →';
    }
  });
</script>
